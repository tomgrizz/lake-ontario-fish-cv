<!--
Label Studio labeling interface for salmonid species review.

SETUP
-----
1. Set environment variables before starting Label Studio:
     set LABEL_STUDIO_LOCAL_FILES_SERVING_ENABLED=true
     set LABEL_STUDIO_LOCAL_FILES_DOCUMENT_ROOT=C:\path\to\your\clips
   Then: label-studio start

2. Create a new project, paste this XML into the labeling configuration.

3. Import a tasks.json batch generated by import_tasks.py.

REVIEWER WORKFLOW
-----------------
- Video plays when you press the Play button (or Space if Space plays video;
  see SPACE KEY note below).
- The model's top prediction is pre-selected in the species list.
- If the model is correct, just press Submit (or the keyboard shortcut below).
- Change the selection with number keys 1-5 if the model is wrong.
- Use n / m / u for exception cases.
- Label Studio auto-advances to the next task after Submit.

KEYBOARD SHORTCUTS
------------------
  1  Chinook
  2  Coho
  3  Atlantic
  4  Rainbow Trout
  5  Brown Trout
  n  Not a fish
  m  Multiple fish in track
  u  Unsure

SPACE KEY NOTE (verify during step 3 manual test)
--------------------------------------------------
Label Studio's Video tag may or may not use Space to play/pause.
If pressing Space submits the task instead of playing the video:
  - Uncomment the <Script> block below (JS autoplay workaround)
  - Remove the Space-triggers-submit behaviour via Label Studio project settings
    if possible, or change the submit hotkey.
Document the result here after testing.

UNDERSCORE FIELD VERIFICATION (step 3 manual test)
---------------------------------------------------
The task data contains _video_id, _track_id, _batch_id, _calibration,
_multi_reviewed, _model_version, _original_predicted_class_6,
_original_predicted_species, _original_confidence.
These are NOT referenced in this XML so they should be invisible to the reviewer.
After annotating one task and exporting, confirm all _ fields are present in the
export JSON. If predictions[0].model_version and predictions[0].score round-trip
reliably, the _model_version and _original_confidence fields in data are redundant
and can be removed from import_tasks.py.
-->

<View>
  <Style>
    /* Keep the video compact and centred. */
    .lsf-video { margin-bottom: 10px; }
    .lsf-choices { margin-top: 8px; }

    /* Highlight the confirm (pre-selected) choice visually. */
    .lsf-choice_selected { font-weight: bold; }
  </Style>

  <!-- ------------------------------------------------------------------ -->
  <!-- CLIP VIDEO                                                           -->
  <!-- clip_url is generated by import_tasks.py as:                        -->
  <!-- http://localhost:8080/data/local-files/?d=batch_NNN/clip_XXX.mp4    -->
  <!-- ------------------------------------------------------------------ -->
  <Video name="video" value="$clip_url" height="420" />

  <!-- ------------------------------------------------------------------ -->
  <!-- METADATA PANEL                                                       -->
  <!-- task_html is generated by import_tasks.py and contains:             -->
  <!--   - Site name, approximate date/time                                -->
  <!--   - Direction (upstream / downstream / unknown)                     -->
  <!--   - n_frames                                                         -->
  <!--   - Top-2 species confidence bars                                   -->
  <!--   - Background probability (diagnostic for spurious detections)     -->
  <!-- The HTML is pre-rendered so no XML template logic is needed here.   -->
  <!-- ------------------------------------------------------------------ -->
  <HyperText name="metadata" value="$task_html" inline="true"
             selectionEnabled="false" />

  <!-- ------------------------------------------------------------------ -->
  <!-- SPECIES / ACTION CHOICE                                              -->
  <!--                                                                     -->
  <!-- The model's top prediction is pre-selected via the task's           -->
  <!-- predictions[] array. "Confirm" = submit without changing selection. -->
  <!--                                                                     -->
  <!-- IMPORTANT: hotkey values below must not conflict with Label Studio   -->
  <!-- built-in shortcuts. Verify 1-5, n, m, u are free in your LS        -->
  <!-- version. If any conflict, change here and in REVIEWER_GUIDE.md.    -->
  <!-- ------------------------------------------------------------------ -->
  <Choices name="label" toName="video" choice="single" required="true"
           showInline="false">
    <Choice value="Chinook"        hotkey="1" hint="Chinook Salmon" />
    <Choice value="Coho"           hotkey="2" hint="Coho Salmon" />
    <Choice value="Atlantic"       hotkey="3" hint="Atlantic Salmon" />
    <Choice value="Rainbow Trout"  hotkey="4" hint="Rainbow Trout / Steelhead" />
    <Choice value="Brown Trout"    hotkey="5" hint="Brown Trout" />
    <Choice value="Not a fish"     hotkey="n" hint="Debris, shadow, lens artifact, or empty frame" />
    <Choice value="Multiple fish"  hotkey="m" hint="Track contains more than one individual" />
    <Choice value="Unsure"         hotkey="u" hint="Cannot determine species — flag for senior review" />
  </Choices>

  <!--
  AUTOPLAY WORKAROUND (uncomment if Space submits instead of playing video)
  =========================================================================
  If the Space key submits the task before reviewers can watch the clip,
  uncomment this Script block. It auto-plays the video when the task loads
  and loops it. Test with Space key after uncommenting.

  <Script>
    (function() {
      function autoplayVideo() {
        var videos = document.querySelectorAll('video');
        videos.forEach(function(v) {
          v.loop = true;
          v.play().catch(function() {});
        });
      }
      // Attempt immediately and after a short delay for LS rendering lag.
      autoplayVideo();
      setTimeout(autoplayVideo, 800);

      // Re-trigger on task navigation (LS replaces the DOM).
      var observer = new MutationObserver(function() {
        autoplayVideo();
      });
      observer.observe(document.body, { childList: true, subtree: true });
    })();
  </Script>
  -->

</View>
